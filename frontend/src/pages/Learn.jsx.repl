"const parseSections = (markdownText) => {\n  if (!markdownText) return [];\n  const lines = markdownText.split('\\n');\n  const sections = [];\n  let current = null;\n\n  for (const line of lines) {\n    const match = line.match(/^##\\s+(\\d+)\\.\\s+(.+)/);\n    if (match) {\n      if (current) sections.push(current);\n      current = { number: parseInt(match[1]), title: match[2].trim(), content: line + '\\n' };\n    } else if (current) {\n      current.content += line + '\\n';\n    }\n  }\n  if (current) sections.push(current);\n\n  // Fallback: if no numbered ## sections found (e.g. generatedLessons.json format),\n  // show the entire content as a single non-paginated page\n  if (sections.length === 0 && markdownText.trim()) {\n    return [{ number: 1, title: 'Content', content: markdownText, isFallback: true }];\n  }\n\n  return sections;\n};"